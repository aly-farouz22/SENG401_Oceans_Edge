generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Stores one row per player — identified by a username they enter
model Player {
  id        String   @id @default(cuid())
  username  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gameState   GameState?
  choices     Choice[]
  outcomes    GameOutcome[]
}

// Stores the full game state for a player as a JSON file
model GameState {
  id           String   @id @default(cuid())
  playerId     String   @unique
  state        Json     // money, season, coralHealth, pollutionLevel
  achievements Json     @default("{}") // unlocked badge IDs and player stats
  updatedAt    DateTime @updatedAt

  player       Player   @relation(fields: [playerId], references: [id])
}

// Logs individual player decisions during gameplay.
model Choice {
  id         String   @id @default(cuid())
  playerId   String
  decision   String
  details    Json?
  createdAt  DateTime @default(now())

  player     Player   @relation(fields: [playerId], references: [id])
}

// Stores the final result when a game session ends.
model GameOutcome {
  id             String   @id @default(cuid())
  playerId       String
  result         String
  finalBalance   Int
  seasonsPlayed  Int
  coralHealth    Float
  pollutionLevel Float
  extinctSpecies String[]
  createdAt      DateTime @default(now())

  player         Player   @relation(fields: [playerId], references: [id])
}
